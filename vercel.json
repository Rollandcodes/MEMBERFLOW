{
  "builds": [
    {
      "src": "package.json",
      "use": "@vercel/next"
    }
  ],
  "crons": [
    {
      "path": "/api/cron/process-campaigns",
      "schedule": "0 * * * *"
    }
  ],
  "rewrites": [
    {
      "source": "/api/messages/process",
      "destination": "/api/cron/process-campaigns"
    }
  ]
}
