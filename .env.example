WHOP_APP_ID="your_whop_app_id"
WHOP_COMPANY_ID="your_whop_company_id"
WHOP_CUSTOMER_USER_ID="your_whop_customer_user_id"
WHOP_AGENT_USER_ID="your_whop_agent_user_id"
WHOP_API_KEY="your_whop_api_key"

# Whop Public Keys
NEXT_PUBLIC_WHOP_APP_ID="your_whop_app_id"
NEXT_PUBLIC_WHOP_CLIENT_ID="your_whop_client_id"
NEXT_PUBLIC_WHOP_REDIRECT_URL="https://memberflow-eight.vercel.app/api/auth/callback/whop"
NEXT_PUBLIC_WHOP_GROWTH_PLAN_ID="your_growth_plan_id"
